# OAuth2 credentials (server-side only — never use NEXT_PUBLIC_ prefix)
OAUTH_TOKEN_URL=https://is-wso2-dev.101digital.io/t/101digital.core/oauth2/token
OAUTH_CLIENT_ID=your_client_id
OAUTH_CLIENT_SECRET=your_client_secret

# 101 Digital API base URL
API_BASE_URL=https://api-neobank-dev.101digital.io

# Cookie Secure flag (optional)
# Enabled automatically when NODE_ENV=production.
# Set to true for local HTTPS or staging over HTTPS.
# COOKIE_SECURE=true
